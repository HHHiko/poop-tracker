/* app.wxss — 全局样式：粗黑描边漫画风 */

/* ====== 基础色板（注释约定） ====== */
/*
  主背景:   #EFEBE9  暖米白
  卡片背景: #FFFFFF  白色
  主色调:   #A1887F  暖棕色
  描边色:   #2C2C2C  漫画黑
  主文字:   #2C2C2C  深色
  次文字:   #666666  灰色
  危险色:   #EF5350  红色
*/

/* ====== 页面基础 ====== */
page {
  background-color: #EFEBE9;
  font-size: 28rpx;
  color: #2C2C2C;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  box-sizing: border-box;
}

/* ====== 通用卡片 — 粗黑描边 + 漫画阴影 ====== */
.card {
  background-color: #FFFFFF;
  border: 3rpx solid #2C2C2C;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 16rpx 32rpx;
  box-shadow: 4rpx 4rpx 0 #2C2C2C;
}

/* ====== 主按钮 — 漫画风 ====== */
.btn-primary {
  background-color: #A1887F;
  color: #FFFFFF;
  border: 3rpx solid #2C2C2C;
  border-radius: 12rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 3rpx 3rpx 0 #2C2C2C;
}

.btn-primary:active {
  background-color: #795548;
  box-shadow: 1rpx 1rpx 0 #2C2C2C;
  transform: translate(2rpx, 2rpx);
}

/* ====== 通用间距 ====== */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.p-24 { padding: 24rpx; }

/* ====== 通用文字 ====== */
.text-center { text-align: center; }
.text-secondary { color: #666666; }
.text-small { font-size: 24rpx; }
