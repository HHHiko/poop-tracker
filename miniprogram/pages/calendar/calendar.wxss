/* pages/calendar/calendar.wxss — 粗黑描边漫画风 */

.page {
  min-height: 100vh;
  background-color: #EFEBE9;
  padding: 32rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

/* ====== 月份导航 ====== */
.month-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  margin-bottom: 16rpx;
}
.nav-arrow {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 40rpx;
  color: #2C2C2C;
  font-weight: bold;
  background: #FFFFFF;
  border: 3rpx solid #2C2C2C;
  border-radius: 12rpx;
  box-shadow: 3rpx 3rpx 0 #2C2C2C;
}
.nav-arrow:active {
  background: #F0F0F0;
  box-shadow: 1rpx 1rpx 0 #2C2C2C;
  transform: translate(2rpx, 2rpx);
}
.month-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2C2C2C;
}

/* ====== 星期头 ====== */
.weekday-row {
  display: flex;
  margin-bottom: 4rpx;
}
.weekday-cell {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
}
.weekday-text {
  font-size: 26rpx;
  color: #666666;
  font-weight: 700;
}

/* ====== 日期网格 — 粗黑大框 ====== */
.calendar-grid {
  background: #FFFFFF;
  border: 3rpx solid #2C2C2C;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 4rpx 4rpx 0 #2C2C2C;
}
.week-row {
  display: flex;
}
.week-row:not(:last-child) {
  border-bottom: 2rpx solid #2C2C2C;
}

.day-cell {
  flex: 1;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 6rpx;
  position: relative;
  box-sizing: border-box;
}
.day-cell:not(:last-child) {
  border-right: 2rpx solid #E8E8E8;
}

.day-cell.current {
  /* 正常可点击 */
}
.day-cell.prev,
.day-cell.next {
  opacity: 0.25;
}

/* 今天高亮 */
.day-cell.today {
  background-color: #D7CCC8;
}
.day-cell.today .day-num {
  color: #2C2C2C;
  font-weight: bold;
}

/* 选中日期高亮 */
.day-cell.selected {
  background-color: #A1887F;
}
.day-cell.selected .day-num {
  color: #FFFFFF;
  font-weight: bold;
}

.day-num {
  font-size: 28rpx;
  color: #2C2C2C;
  font-weight: 500;
}
.day-num.dimmed {
  color: #BDBDBD;
}

/* ====== 标记方块（像素风小方块代替圆点） ====== */
.dots-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 5rpx;
  margin-top: 4rpx;
  max-width: 85%;
}
.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 2rpx;
  border: 1.5rpx solid rgba(44, 44, 44, 0.5);
  flex-shrink: 0;
}

/* ====== 经期标记 ====== */
.period-bar {
  width: 60%;
  height: 6rpx;
  background-color: #F48FB1;
  border-radius: 3rpx;
  margin-top: 4rpx;
  border: 1rpx solid #E91E63;
}

/* ====== 预测经期标记 — 虚线风格区分 ====== */
.day-cell.period-predicted {
  background-color: rgba(244, 143, 177, 0.08);
}
.period-predicted-bar {
  width: 60%;
  height: 6rpx;
  border-radius: 3rpx;
  margin-top: 4rpx;
  /* 用渐变模拟虚线 */
  background: repeating-linear-gradient(
    90deg,
    #F48FB1 0rpx,
    #F48FB1 8rpx,
    transparent 8rpx,
    transparent 14rpx
  );
}

/* ====== 日预览面板 ====== */
.day-preview {
  margin-top: 24rpx;
  background: #FFFFFF;
  border: 3rpx solid #2C2C2C;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 4rpx 4rpx 0 #2C2C2C;
  animation: previewSlideIn 0.2s ease-out;
}
@keyframes previewSlideIn {
  from { opacity: 0; transform: translateY(-12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* 预览头部 */
.preview-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #E8E8E8;
}
.preview-close {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  font-weight: bold;
  background: #FFFFFF;
  border: 2rpx solid #2C2C2C;
  border-radius: 8rpx;
  box-shadow: 2rpx 2rpx 0 #2C2C2C;
  flex-shrink: 0;
}
.preview-close-pressed {
  background: #F0F0F0 !important;
  box-shadow: 1rpx 1rpx 0 #2C2C2C !important;
  transform: translate(1rpx, 1rpx);
}
.preview-date {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #2C2C2C;
}
.preview-hint {
  font-size: 22rpx;
  color: #999999;
}

/* 预览空状态 */
.preview-empty {
  text-align: center;
  padding: 32rpx 0;
}
.preview-empty-emoji {
  font-size: 72rpx;
  display: block;
  margin-bottom: 16rpx;
}
.preview-empty-text {
  font-size: 28rpx;
  color: #666666;
  font-weight: bold;
}

/* 预览记录列表 */
.preview-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  max-height: 500rpx;
  overflow-y: auto;
}

/* 预览记录项 */
.preview-item {
  display: flex;
  align-items: center;
  background: #FAFAFA;
  border: 2rpx solid #E0E0E0;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
}
.preview-item-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  min-width: 70rpx;
}
.preview-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 3rpx;
  border: 2rpx solid #2C2C2C;
}
.preview-time {
  font-size: 24rpx;
  font-weight: 700;
  color: #2C2C2C;
}
.preview-item-mid {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 12rpx;
}
.preview-icon {
  width: 36rpx;
  height: 36rpx;
}
.preview-type {
  font-size: 26rpx;
  font-weight: bold;
  color: #2C2C2C;
}
.preview-item-right {
  max-width: 200rpx;
  flex: 1;
}
.preview-note {
  font-size: 22rpx;
  color: #666666;
  word-break: break-all;
}

/* 预览删除按钮 */
.preview-delete-btn {
  width: 52rpx;
  height: 52rpx;
  min-width: 52rpx;
  background: #EF5350;
  border: 2rpx solid #2C2C2C;
  border-radius: 8rpx;
  box-shadow: 2rpx 2rpx 0 #2C2C2C;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  flex-shrink: 0;
}
.preview-delete-icon {
  font-size: 28rpx;
  line-height: 1;
}
.preview-delete-btn-pressed {
  background: #C62828 !important;
  box-shadow: 1rpx 1rpx 0 #2C2C2C !important;
  transform: translate(1rpx, 1rpx);
}

/* 跳转详情链接 */
.preview-detail-link {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #E8E8E8;
  text-align: center;
}
.preview-detail-text {
  font-size: 26rpx;
  color: #A1887F;
  font-weight: bold;
  text-decoration: underline;
}
.preview-detail-link-pressed {
  opacity: 0.7;
}

/* ====== 图例 ====== */
.legend {
  margin-top: 28rpx;
  background: #FFFFFF;
  border: 3rpx solid #2C2C2C;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 4rpx 4rpx 0 #2C2C2C;
}
.legend-title {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
  font-weight: bold;
}
.legend-items {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 24rpx;
}
.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 3rpx;
  border: 2rpx solid #2C2C2C;
}
.legend-label {
  font-size: 24rpx;
  color: #2C2C2C;
  font-weight: 500;
}
.period-legend {
  background-color: #F48FB1;
}
.period-predicted-legend {
  background: repeating-linear-gradient(
    90deg,
    #F48FB1 0rpx,
    #F48FB1 4rpx,
    transparent 4rpx,
    transparent 8rpx
  );
}
