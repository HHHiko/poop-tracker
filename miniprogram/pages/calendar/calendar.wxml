<!-- pages/calendar/calendar.wxml — 月历页 -->
<view class="page">

  <!-- 月份导航 -->
  <view class="month-nav">
    <view class="nav-arrow" bindtap="goPrevMonth">〈</view>
    <view class="month-title">{{year}}年 {{month}}月</view>
    <view class="nav-arrow" bindtap="goNextMonth">〉</view>
  </view>

  <!-- 星期头 -->
  <view class="weekday-row">
    <view class="weekday-cell" wx:for="{{weekdays}}" wx:key="*this">
      <text class="weekday-text">{{item}}</text>
    </view>
  </view>

  <!-- 日期网格 -->
  <view class="calendar-grid">
    <view class="week-row" wx:for="{{weeks}}" wx:key="index">
      <view
        class="day-cell {{item.month}} {{item.isToday ? 'today' : ''}} {{day.isPeriod ? 'period-day' : ''}} {{day.isPredicted ? 'period-predicted' : ''}} {{selectedDate === day.dateStr ? 'selected' : ''}}"
        wx:for="{{item}}"
        wx:for-item="day"
        wx:key="col"
        data-item="{{day}}"
        bindtap="onDayTap"
      >
        <!-- 日期数字 -->
        <text class="day-num {{day.month === 'current' ? '' : 'dimmed'}}">{{day.day}}</text>

        <!-- 便便类型标记方块（每条记录一个点） -->
        <view class="dots-row" wx:if="{{day.dots.length > 0}}">
          <view
            class="dot"
            wx:for="{{day.dots}}"
            wx:for-item="dot"
            wx:key="index"
            style="background-color: {{stoolTypes[dot - 1].color}};"
          ></view>
        </view>

        <!-- 经期标记：粉色小横条 -->
        <view class="period-bar" wx:if="{{day.isPeriod}}"></view>
        <!-- 预测经期：虚线横条 -->
        <view class="period-predicted-bar" wx:if="{{day.isPredicted}}"></view>
      </view>
    </view>
  </view>

  <!-- ====== 日预览面板 ====== -->
  <view class="day-preview" wx:if="{{selectedDate}}">
    <!-- 头部 -->
    <view class="preview-header">
      <view class="preview-close" bindtap="onDeselectDate" hover-class="preview-close-pressed">✕</view>
      <text class="preview-date">📅 {{selectedDate}}</text>
      <text class="preview-hint">点击日期切换</text>
    </view>

    <!-- 空状态 -->
    <view class="preview-empty" wx:if="{{previewRecords.length === 0}}">
      <text class="preview-empty-emoji">📭</text>
      <text class="preview-empty-text">这天还没有记录</text>
    </view>

    <!-- 记录列表 -->
    <view class="preview-list" wx:else>
      <view class="preview-item" wx:for="{{previewRecords}}" wx:key="id">
        <view class="preview-item-left">
          <view class="preview-dot" style="background-color: {{stoolTypes[item.stoolType - 1].color}};"></view>
          <text class="preview-time">{{item.time}}</text>
        </view>
        <view class="preview-item-mid">
          <image class="preview-icon" src="{{stoolTypes[item.stoolType - 1].icon}}" mode="aspectFit"></image>
          <text class="preview-type">{{stoolTypes[item.stoolType - 1].name}}</text>
        </view>
        <view class="preview-item-right">
          <text class="preview-note" wx:if="{{item.note}}">{{item.note}}</text>
        </view>
        <view class="preview-delete-btn" data-id="{{item.id}}" catchtap="onPreviewDelete" hover-class="preview-delete-btn-pressed">
          <text class="preview-delete-icon">🗑</text>
        </view>
      </view>
    </view>

    <!-- 跳转完整详情页 -->
    <view class="preview-detail-link" bindtap="onGoToDetail" hover-class="preview-detail-link-pressed">
      <text class="preview-detail-text">查看详情（导入/导出）→</text>
    </view>
  </view>

  <!-- 图例：状态描述 -->
  <view class="legend">
    <text class="legend-title">状态说明：</text>
    <view class="legend-items">
      <view class="legend-item" wx:for="{{stoolTypes}}" wx:key="value">
        <view class="legend-dot" style="background-color: {{item.color}};"></view>
        <text class="legend-label">{{item.desc}}</text>
      </view>
      <view class="legend-item">
        <view class="legend-dot period-legend"></view>
        <text class="legend-label">经期</text>
      </view>
      <view class="legend-item" wx:if="{{prediction}}">
        <view class="legend-dot period-predicted-legend"></view>
        <text class="legend-label">预测经期</text>
      </view>
    </view>
  </view>

</view>
